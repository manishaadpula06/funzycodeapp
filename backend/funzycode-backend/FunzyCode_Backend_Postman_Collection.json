{
  "info": {
    "name": "FunzyCode Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/register",
        "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Hari Prasad\",\n  \"email\": \"hari@example.com\",\n  \"password\": \"123456\"\n}" }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"hari@example.com\",\n  \"password\": \"123456\"\n}" }
      }
    },
    {
      "name": "Auth - Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/auth/me"
      }
    },
    {
      "name": "Game - Progress",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/game/progress"
      }
    },
    {
      "name": "Level - Complete 1",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/levels/1/complete",
        "body": { "mode": "raw", "raw": "{\n  \"submittedCode\": \"moveForward(); jump();\",\n  \"secondsLeft\": 35,\n  \"starsEarned\": 3,\n  \"coinsEarned\": 100\n}" }
      }
    },
    {
      "name": "Gift - Open Level 1",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/gifts/1/open",
        "body": { "mode": "raw", "raw": "{\n  \"giftId\": \"gift-level-1\"\n}" }
      }
    },
    {
      "name": "Reward - WhatsApp",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/rewards/whatsapp"
      }
    },
    {
      "name": "Mini Game - Save Score",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/mini-games/scores",
        "body": { "mode": "raw", "raw": "{\n  \"gameName\": \"MazeEscapeScreen\",\n  \"score\": 1200,\n  \"coinsEarned\": 50,\n  \"starsEarned\": 1,\n  \"durationSeconds\": 90\n}" }
      }
    },
    {
      "name": "Mini Game - Leaderboard",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/mini-games/leaderboard/MazeEscapeScreen"
      }
    }
  ]
}
